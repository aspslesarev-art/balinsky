# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# secrets & generated reports
gsc-service-account.json
*-service-account.json
/reports/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local script caches & outputs (regeneratable, too big for git)
/scripts/_*.json
/scripts/out/

# ad-hoc debug snippets at repo root
/check*.mjs
/checklogo.mjs
scripts/estatemarket_cards.json
estatemarket_occupancy_report.xlsx
scripts/_ai-fallback-cache.json

# Local working files — not for the catalog
BALINSKY_REPORT.md
estatemarket_occupancy_*.xlsx
scripts/__pycache__/

graphify-out/
